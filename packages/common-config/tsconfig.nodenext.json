{
    "compilerOptions": {
        "lib": [
            "ESNext"
        ],
        "moduleResolution": "nodenext",
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "removeComments": true,
        "sourceMap": true,
        "target": "ES2024",
        "module": "NodeNext",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
    }
}
